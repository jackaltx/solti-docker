# Ansible managed — do not edit directly
[global]
server_name = "{{ conduit_host }}.{{ domain }}"

database_backend = "rocksdb"
database_path = "/var/lib/matrix-conduit/"

address = "0.0.0.0"
port = {{ conduit_port }}

max_request_size = {{ conduit_max_request_size }}

allow_registration = {{ conduit_allow_registration }}
allow_federation = {{ conduit_allow_federation }}

trusted_servers = [{% for s in conduit_trusted_servers %}"{{ s }}"{% if not loop.last %}, {% endif %}{% endfor %}]

max_concurrent_requests = {{ conduit_max_concurrent_requests }}
